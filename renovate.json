{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:best-practices", ":labels(dependencies)", ":automergeStableNonMajor"],
    "minimumReleaseAge": "7 days",
    "dependencyDashboard": true,
    "rangeStrategy": "bump",
    "packageRules": [
        {
            "matchPackageNames": ["axeleroy/slack-app-in-tab/.github/workflows/publish.yml"],
            "pinDigests": false
        }
    ]
}
