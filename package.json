{
    "name": "slack-app-in-tab",
    "version": "1.0.0",
    "description": "A Chrome + Firefox extension to open the Slack app with its multi-workspace sidebar in a simple browser tab.",
    "scripts": {
        "update-ua": "ts-node ua-update/index.ts",
        "build": "web-ext build --overwrite-dest -s src/",
        "test": "vitest",
        "lint": "web-ext lint -s src/",
        "sign": "web-ext sign -s src/",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^24.12.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "memfs": "^4.56.11",
        "prettier": "3.8.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vitest": "^4.1.0",
        "web-ext": "^10.0.0"
    },
    "dependencies": {
        "@actions/core": "^2.0.3",
        "fontoxpath": "^3.34.0",
        "jsdom": "^29.0.1"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    }
}
