{
    "name": "slack-app-in-tab",
    "version": "1.0.0",
    "description": "A Chrome + Firefox extension to open the Slack app with its multi-workspace sidebar in a simple browser tab.",
    "type": "module",
    "scripts": {
        "update-ua": "ts-node ua-update/index.ts",
        "build": "web-ext build --overwrite-dest -s src/",
        "test": "vitest",
        "lint": "web-ext lint -s src/",
        "sign": "web-ext sign -s src/",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/jsdom": "28.0.1",
        "@types/node": "24.12.2",
        "eslint": "10.3.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "globals": "17.6.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "memfs": "4.57.2",
        "prettier": "3.8.3",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.2",
        "vitest": "4.1.5",
        "web-ext": "10.1.0"
    },
    "dependencies": {
        "@actions/core": "^3.0.1",
        "fontoxpath": "^3.34.0",
        "jsdom": "^29.1.1"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    },
    "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489"
}
